# Public Supabase project URL: Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key: Supabase dashboard > Project Settings > API
# This key is safe for browser use only because the migration enables strict RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public production address used by share links.
NEXT_PUBLIC_SITE_URL=https://saxmundham-rail-watch.netlify.app

# Server-only key: Supabase dashboard > Project Settings > API > service_role
# Never prefix this with NEXT_PUBLIC_ and never commit its real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Random 32+ character value used to bind duplicate-submission tokens.
SUBMISSION_SECRET=replace-with-a-long-random-value

# Development-only owner decisions. Replace before public launch.
DATA_CONTROLLER_NAME=
PRIVACY_CONTACT_EMAIL=
CONTACT_RETENTION_DAYS=365
